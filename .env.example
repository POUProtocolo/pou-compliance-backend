# Porta do backend
PORT=8787

# Origem permitida do site estático
ALLOWED_ORIGIN=https://poureservavalor.com

# Modo global de fallback: clear | blocked | unavailable
COMPLIANCE_MODE=unavailable

# Modos por provedor (opcional)
CHAINALYSIS_MODE=
ELLIPTIC_MODE=
TRM_MODE=

# Se quiser fazer proxy para um backend real seu, preencha:
CHAINALYSIS_UPSTREAM_URL=
ELLIPTIC_UPSTREAM_URL=
TRM_UPSTREAM_URL=

# Headers opcionais para upstreams próprios
CHAINALYSIS_API_KEY=
ELLIPTIC_API_KEY=
TRM_API_KEY=
